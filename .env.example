# ── Telegram ────────────────────────────────────────────────
# Cree un bot via @BotFather -> /newbot -> recupere le token.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# chat_id de Lydia (ou d'un groupe). Voir README pour le recuperer.
TELEGRAM_CHAT_ID=123456789

# ── Supabase (persistance des annonces deja vues) ───────────
SUPABASE_URL=https://xxxx.supabase.co
# Cle "service_role" (cote serveur uniquement, ne jamais exposer cote client)
SUPABASE_SERVICE_KEY=eyJhbGci...

# ── Comportement ────────────────────────────────────────────
# loop = process permanent (Railway / VPS).  once = un seul passage (GitHub Actions / cron externe).
MODE=loop
# Frequence du poll en mode loop (syntaxe cron). Defaut: toutes les 5 min.
INTERVAL_CRON=*/5 * * * *
# Petit delai aleatoire (ms) entre deux sites pour rester poli.
POLITE_DELAY_MS=1500

# Filtre prix : ignore les biens sous ce montant (en euros). 0 = pas de filtre.
MIN_PRICE=300000
# Garder les annonces sans prix affiche ("prix sur demande") : 1 = oui (defaut), 0 = exclure.
KEEP_UNKNOWN_PRICE=1

# Mets a 1 pour utiliser un navigateur headless (Playwright) sur les sites JS.
# Necessite: npx playwright install chromium
USE_PLAYWRIGHT=0

# Debug: 1 = affiche ce qui est parse sans notifier (calibration des selecteurs).
DEBUG_SCRAPE=0
# Seed: 1 = marque tout comme "vu" sans notifier (a lancer une fois au depart).
SEED_ONLY=0

# ── Bridge e-mail : Leboncoin / Seloger via alertes ─────────
# 1 = active la lecture des alertes e-mail des portails.
EMAIL_ENABLED=0
# Boite mail DEDIEE aux alertes (cree un compte/alias rien que pour ca).
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=veille.immo@gmail.com
# Gmail : "mot de passe d'application" (2FA requise), pas le mot de passe normal.
IMAP_PASSWORD=xxxx xxxx xxxx xxxx
# Dossier/label ou arrivent les alertes (via un filtre Gmail). Defaut: INBOX.
IMAP_MAILBOX=Alertes-Immo
