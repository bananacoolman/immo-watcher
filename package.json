{
  "name": "immo-watcher",
  "version": "1.0.0",
  "description": "Bot de veille concurrentielle immobilière -> notifications Telegram",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "once": "MODE=once node src/index.js",
    "debug": "MODE=once DEBUG_SCRAPE=1 node src/index.js",
    "seed": "MODE=once SEED_ONLY=1 node src/index.js",
    "digest": "MODE=digest node src/index.js",
    "digest:debug": "MODE=digest DEBUG_SCRAPE=1 node src/index.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.5",
    "imapflow": "^1.0.171",
    "mailparser": "^3.7.1",
    "node-cron": "^3.0.3"
  },
  "optionalDependencies": {
    "playwright": "^1.47.0"
  },
  "engines": {
    "node": ">=18"
  }
}
